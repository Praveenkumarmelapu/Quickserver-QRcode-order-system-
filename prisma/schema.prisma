datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("STAFF") // "ADMIN", "KITCHEN", "STAFF"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Table {
  id             String          @id @default(uuid())
  tableNumber    Int             @unique
  capacity       Int
  qrToken        String          @unique
  status         String          @default("AVAILABLE") // "AVAILABLE", "OCCUPIED", "BILLING", "DIRTY"
  orders         Order[]
  waiterRequests WaiterRequest[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String      @id @default(uuid())
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String
  image       String?
  price       Float
  isVeg       Boolean     @default(false)
  available   Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id         String      @id @default(uuid())
  tableId    String
  table      Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  status     String      @default("PENDING") // "PENDING", "ACCEPTED", "PREPARING", "READY", "SERVED", "COMPLETED"
  subtotal   Float
  tax        Float
  total      Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  quantity   Int
  notes      String?
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WaiterRequest {
  id        String   @id @default(uuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  type      String   // "ASSISTANCE" or "BILL"
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
